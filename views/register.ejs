<%- include('partials/head', { title: '회원가입' }) %>
<%- include('partials/style') %>

<div class="auth-wrap">
    <div class="auth-box">
        <div class="logo">
            <h1>SKUL_R</h1>
            <p>게임 기록 및 채팅 웹서비스</p>
        </div>
        <div class="auth-card">
            <h2>회원가입</h2>
            <form id="registerForm">
                <div class="form-group">
                    <label>닉네임</label>
                    <input type="text" id="username" placeholder="게임 닉네임" required maxlength="30">
                </div>
                <div class="form-group">
                    <label>아이디</label>
                    <input type="text" id="stringID" placeholder="로그인에 사용할 아이디" required maxlength="126">
                </div>
                <div class="form-group">
                    <label>비밀번호</label>
                    <input type="password" id="pw" placeholder="비밀번호" required maxlength="90">
                </div>
                <div class="form-group">
                    <label>비밀번호 확인</label>
                    <input type="password" id="pwConfirm" placeholder="비밀번호 재입력" required>
                </div>
                <button type="submit" class="btn btn-primary btn-full" id="regBtn">
                    계정 만들기
                </button>
            </form>
            <div class="auth-link">
                이미 계정이 있으신가요? <a href="/login">로그인</a>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('registerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('regBtn');

    const PID      = Number(document.getElementById('pid')?.value);
    const UserName = document.getElementById('username').value;
    const StringID = document.getElementById('stringID').value;
    const PW       = document.getElementById('pw').value;
    const pwC      = document.getElementById('pwConfirm').value;

    if (PW !== pwC) return showToast('비밀번호가 일치하지 않습니다.', 'error');

    btn.disabled = true; btn.textContent = '처리 중...';

    try {
        const res  = await fetch('/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ StringID, PW, UserName })
        });
        const data = await res.json();

        if (data.success) {
            showToast(`회원가입 완료! 발급된 PID: ${data.PID}`, 'success');
            setTimeout(() => location.href = '/login', 1500);
        } else {
            showToast(data.message || '회원가입 실패', 'error');
            btn.disabled = false; btn.textContent = '계정 만들기';
        }
    } catch {
        showToast('서버 연결 오류', 'error');
        btn.disabled = false; btn.textContent = '계정 만들기';
    }
});
</script>
<%- include('partials/foot') %>
