<%- include('partials/head', { title: '로그인' }) %>
<%- include('partials/style') %>

<div class="auth-wrap">
    <div class="auth-box">
        <div class="logo">
            <h1>SKUL_R</h1>
            <p>게임 기록및 채팅 웹서비스</p>
        </div>
        <div class="auth-card">
            <h2>로그인</h2>
            <form id="loginForm">
                <div class="form-group">
                    <label>아이디</label>
                    <input type="text" id="stringID" placeholder="아이디를 입력하세요" required autocomplete="username">
                </div>
                <div class="form-group">
                    <label>비밀번호</label>
                    <input type="password" id="pw" placeholder="비밀번호를 입력하세요" required autocomplete="current-password">
                </div>
                <div style="margin-top:.5rem">
                    <button type="submit" class="btn btn-primary btn-full" id="loginBtn">
                        <span>로그인</span>
                    </button>
                </div>
            </form>
            <div class="auth-link">
                계정이 없으신가요? <a href="/register">회원가입</a>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('loginBtn');
    btn.disabled = true;
    btn.innerHTML = '<span>로그인 중...</span>';

    const StringID = document.getElementById('stringID').value;
    const PW       = document.getElementById('pw').value;

    try {
        const res  = await fetch('/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ StringID, PW })
        });
        const data = await res.json();

        if (data.success) {
            localStorage.setItem('session', data.session);
            localStorage.setItem('PID',     data.PID);
            showToast('로그인 성공!', 'success');
            setTimeout(() => location.href = '/dashboard', 800);
        } else {
            showToast(data.message || '로그인 실패', 'error');
            btn.disabled = false;
            btn.innerHTML = '<span>로그인</span>';
        }
    } catch {
        showToast('서버 연결 오류', 'error');
        btn.disabled = false;
        btn.innerHTML = '<span>로그인</span>';
    }
});
</script>
<%- include('partials/foot') %>
